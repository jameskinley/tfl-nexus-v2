# TfL Nexus v2 Configuration
# Copy this file to .env and fill in your values

# TfL API Configuration
TFL_API_KEY=your_tfl_api_key_here
TFL_APP_ID=your_tfl_app_id_here

# LLM Summarizer Configuration (Backend)
# Set USE_LLM_SUMMARIZER to 'true' to enable LLM-based report summaries
USE_LLM_SUMMARIZER=false
LLM_API_ENDPOINT=https://api.example.com/v1/completions
LLM_API_KEY=your_llm_api_key_here

# Logging Configuration (Optional)
LOG_LEVEL=INFO

# DB Configuration. Be aware this runs within docker so the host is 'database' not 'localhost'!
DB_USER=tfl
DB_PASSWORD=tfl_password
DB_NAME=tfl_nexus
DB_PORT=5432
DB_HOST=database